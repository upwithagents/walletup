generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// One agent pass that produced proposals (categorization sweep, checks run, …)
model AgentRun {
  id        String     @id @default(cuid())
  runDate   DateTime
  type      String // categorization | checks | evaluation
  summary   String?
  proposals Proposal[]
  createdAt DateTime   @default(now())
}

// A single agent suggestion awaiting human review.
// status: proposal -> approved | rejected -> applied
model Proposal {
  id             String        @id @default(cuid())
  run            AgentRun      @relation(fields: [runId], references: [id])
  runId          String
  section        String // grouping shown in the queue (e.g. "High confidence")
  kind           String // categorize | delete_duplicate | fix_category | remove_label | open_question
  walletRecordId String? // record id in the finance provider (null for batch-level questions)
  title          String // merchant / short description + amount
  detail         String // date • account • context
  proposedAction String // human-readable proposed change
  actionData     String? // JSON payload for the apply step (category ids, label ids, …)
  evidence       String
  recordData     String? // JSON snapshot of the provider record for display (amount, account, labels, colors)
  confidence     String // high | medium | low | needs_input
  status         String        @default("proposal")
  reviewNote     String?
  reviewedAt     DateTime?
  appliedAt      DateTime?
  learningNote   LearningNote?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// What the agent learned from the human's decision on a proposal —
// fed back into future categorization prompts.
model LearningNote {
  id         String   @id @default(cuid())
  proposal   Proposal @relation(fields: [proposalId], references: [id])
  proposalId String   @unique
  lesson     String
  createdAt  DateTime @default(now())
}

// Shared memory store — written from every surface (Discord, web app,
// Claude Code sessions) so knowledge survives regardless of where the
// user gave it.
model Memory {
  id        String   @id @default(cuid())
  kind      String // fact | session_note | feedback
  content   String
  tags      String? // comma-separated, e.g. "proposal:abc123,categorize"
  source    String // discord | app | claude_session | seed
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Registry of hub-managed Discord agents (advisor + ephemeral reviewers).
model HubAgent {
  id           String           @id @default(cuid())
  name         String           @unique
  kind         String // advisor | monthly_reviewer | checks_runner
  channelId    String
  webhookId    String?
  webhookToken String?
  sessionId    String? // Claude CLI session uuid
  tmuxSession  String?
  adapterPort  Int?
  status       String           @default("offline") // offline | starting | ready | running | dead
  messages     ChannelMessage[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// Audit log of everything flowing through the Discord control plane.
model ChannelMessage {
  id         String    @id @default(cuid())
  discordId  String?   @unique
  channelId  String
  direction  String // inbound | outbound
  authorName String
  agent      HubAgent? @relation(fields: [agentId], references: [id])
  agentId    String?
  content    String
  createdAt  DateTime  @default(now())

  @@index([channelId, createdAt])
}

// One execution of the automated finance health checks (plan 03).
model CheckRun {
  id      String        @id @default(cuid())
  runDate DateTime      @default(now())
  results CheckResult[]
}

model CheckResult {
  id       String   @id @default(cuid())
  run      CheckRun @relation(fields: [runId], references: [id])
  runId    String
  checkId  String // stable slug, e.g. "cc-manual-zero"
  name     String
  status   String // pass | warn | fail
  evidence String
  remedy   String?
}
