generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// One agent pass that produced proposals (categorization sweep, checks run, …)
model AgentRun {
  id        String     @id @default(cuid())
  runDate   DateTime
  type      String // categorization | checks | evaluation
  summary   String?
  proposals Proposal[]
  createdAt DateTime   @default(now())
}

// A single agent suggestion awaiting human review.
// status: proposal -> approved | rejected -> applied
model Proposal {
  id             String        @id @default(cuid())
  run            AgentRun      @relation(fields: [runId], references: [id])
  runId          String
  section        String // grouping shown in the queue (e.g. "High confidence")
  kind           String // categorize | delete_duplicate | fix_category | remove_label | open_question
  walletRecordId String? // record id in the finance provider (null for batch-level questions)
  title          String // merchant / short description + amount
  detail         String // date • account • context
  proposedAction String // human-readable proposed change
  actionData     String? // JSON payload for the apply step (category ids, label ids, …)
  evidence       String
  recordData     String? // JSON snapshot of the provider record for display (amount, account, labels, colors)
  confidence     String // high | medium | low | needs_input
  status         String        @default("proposal")
  reviewNote     String?
  reviewedAt     DateTime?
  appliedAt      DateTime?
  learningNote   LearningNote?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// What the agent learned from the human's decision on a proposal —
// fed back into future categorization prompts.
model LearningNote {
  id         String   @id @default(cuid())
  proposal   Proposal @relation(fields: [proposalId], references: [id])
  proposalId String   @unique
  lesson     String
  createdAt  DateTime @default(now())
}

// Shared memory store — written from every surface (Discord, web app,
// Claude Code sessions) so knowledge survives regardless of where the
// user gave it.
model Memory {
  id        String   @id @default(cuid())
  kind      String // fact | session_note | feedback
  content   String
  tags      String? // comma-separated, e.g. "proposal:abc123,categorize"
  source    String // discord | app | claude_session | seed
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Registry of hub-managed Discord agents (advisor + ephemeral reviewers).
model HubAgent {
  id           String           @id @default(cuid())
  name         String           @unique
  kind         String // advisor | monthly_reviewer | checks_runner
  channelId    String
  webhookId    String?
  webhookToken String?
  sessionId    String? // Claude CLI session uuid
  tmuxSession  String?
  adapterPort  Int?
  status       String           @default("offline") // offline | starting | ready | running | dead
  messages     ChannelMessage[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// Audit log of everything flowing through the Discord control plane.
model ChannelMessage {
  id         String    @id @default(cuid())
  discordId  String?   @unique
  channelId  String
  direction  String // inbound | outbound
  authorName String
  agent      HubAgent? @relation(fields: [agentId], references: [id])
  agentId    String?
  content    String
  createdAt  DateTime  @default(now())

  @@index([channelId, createdAt])
}

// One execution of the automated finance health checks (plan 03).
model CheckRun {
  id      String        @id @default(cuid())
  runDate DateTime      @default(now())
  results CheckResult[]
}

model CheckResult {
  id       String   @id @default(cuid())
  run      CheckRun @relation(fields: [runId], references: [id])
  runId    String
  checkId  String // stable slug, e.g. "cc-manual-zero"
  name     String
  status   String // pass | warn | fail
  evidence String
  remedy   String?
}

// A computed month evaluation (plan 02) — aim vs actual per budget plus
// month totals; the sheet's Budgets tab as data.
model MonthEvaluation {
  id           String          @id @default(cuid())
  month        String // "2026-06"
  computedAt   DateTime        @default(now())
  incomeTotal  Float
  expenseTotal Float
  balance      Float
  budgetPoints Int?
  pointsMethod String? // "provisional-overspend-v1" until the sheet formula is confirmed
  rows         EvaluationRow[]

  @@unique([month])
}

model EvaluationRow {
  id           String          @id @default(cuid())
  evaluation   MonthEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  evaluationId String
  name         String
  kind         String // budget | derived
  aim          Float?
  actual       Float
  currency     String          @default("CZK")
  progress     Float?
}

// ---- Sheet-replacement entities (the app is the system of record) ----

model Todo {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("todo") // todo | doing | done
  notes     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Presentations tab: dated tips/summaries for the family team.
model Tip {
  id         String   @id @default(cuid())
  monthLabel String // "June 2026"
  text       String
  status     String   @default("open") // open | done
  createdAt  DateTime @default(now())
}

// Categories/Labels tab: how sheet concepts map to provider objects.
model CategoryMapping {
  id       String  @id @default(cuid())
  emoji    String?
  name     String
  type     String // Income | Expense | Transfer
  inWallet String
}

// Checks + Distributions tabs: numbered operating procedures.
model Procedure {
  id          String                @id @default(cuid())
  kind        String // check | distribution
  num         Int
  name        String
  description String?
  whenToRun   String?
  notes       String?
  steps       ProcedureStep[]
  completions ProcedureCompletion[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model ProcedureStep {
  id          String    @id @default(cuid())
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  procedureId String
  order       Int
  text        String
}

model ProcedureCompletion {
  id          String    @id @default(cuid())
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  procedureId String
  label       String // "May 2026 (end)"
  completedAt DateTime  @default(now())
}

// Set-Aside tab: monthly reservations toward annual payments/goals.
model SetAsideItem {
  id            String             @id @default(cuid())
  num           Int
  name          String
  description   String?
  dueLabel      String? // "last week of MAY"
  windowLabel   String? // "1st-3rd of Month"
  monthlyAmount Float?
  notes         String?
  progress      SetAsideProgress[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model SetAsideProgress {
  id        String       @id @default(cuid())
  item      SetAsideItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  yearLabel String // "2026"
  saved     Float
  target    Float
}
