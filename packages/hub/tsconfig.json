{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2023"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "../adapter/src/**/*.ts",
    "../memory/src/**/*.ts",
    "../db/src/**/*.ts",
    "../agent/src/**/*.ts",
    "../provider-wallet/src/**/*.ts"
  ]
}
